  .btn { display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%; padding: 14px; border-radius: 12px; font-size: 15px; font-weight: 500; text-decoration: none; margin-bottom: 12px; transition: opacity 0.2s; }
  .btn:hover { opacity: 0.85; }
  .btn-yt { background: #FF0000; color: #fff; }
  .btn-maps { background: #378ADD; color: #fff; }
